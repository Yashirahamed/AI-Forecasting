# ─────────────────────────────────────────────────────────────
# Firebase (Auth only — NO Firestore)
# Setup: console.firebase.google.com → Project Settings → Service Accounts
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# ─────────────────────────────────────────────────────────────
# Supabase (PostgreSQL database + Realtime)
# Setup: supabase.com → Settings → API
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─────────────────────────────────────────────────────────────
# Cloudinary (media storage — avatars, PDFs, community photos)
# Setup: cloudinary.com → Dashboard → API Keys
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────────────────────
# Groq AI (Llama 3 model for all AI features)
# Setup: console.groq.com → API Keys
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# ─────────────────────────────────────────────────────────────
# OpenWeatherMap (current weather + 7-day forecast + AQI)
# Setup: openweathermap.org → My API Keys
# ─────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweathermap_key

# ─────────────────────────────────────────────────────────────
# NewsAPI (weather-related news)
# Setup: newsapi.org → Account → API Key
# ─────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key

# ─────────────────────────────────────────────────────────────
# Email (Nodemailer via Gmail SMTP — for weather alerts)
# Setup: Gmail → App Passwords → generate 16-char password
# ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ─────────────────────────────────────────────────────────────
# ML Microservice (FastAPI on Render)
# Setup: render.com → your deployed FastAPI service URL
# ─────────────────────────────────────────────────────────────
ML_SERVICE_URL=https://your-ml-service.onrender.com

# ─────────────────────────────────────────────────────────────
# Vite Frontend Variables (all must start with VITE_)
# ─────────────────────────────────────────────────────────────
VITE_API_URL=/api
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_SUPABASE_URL=https://your_project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=weathercast_uploads
VITE_GROQ_API_KEY=your_groq_api_key
VITE_OPENWEATHER_KEY=your_openweather_key
