{
  "name": "weathercast-backend",
  "version": "1.0.0",
  "description": "WeatherCast AI Backend — Serverless functions for Vercel",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch api --watch lib --watch middleware --ext ts --exec ts-node -e ts,json api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js"
  },
  "main": "api/server.ts",
  "dependencies": {
    "express": "^4.21.2",
    "firebase-admin": "^13.4.0",
    "@supabase/supabase-js": "^2.50.0",
    "cloudinary": "^2.6.1",
    "groq-sdk": "^0.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "nodemailer": "^7.0.3",
    "express-rate-limit": "^7.5.0",
    "axios": "^1.9.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.10",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.18",
    "@types/cors": "^2.8.17",
    "@types/nodemailer": "^6.4.17"
  }
}
