{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/api/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "backend/api/jobs/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/api/server.ts" },
    { "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|webp|map)", "dest": "/frontend/$1.$2" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ],
  "crons": [
    {
      "path": "/api/jobs/weatherMonitor",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/jobs/badgeChecker",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/jobs/newsRefresh",
      "schedule": "0 2 * * *"
    }
  ]
}
